				{
					"name": "POST /pet",
					"item": [
						{
							"name": "Create a pet",
							"event": [
								{
									"listen": "prerequest",
									"script": {
										"id": "35e6da53-3c52-430f-b81b-f7852ab42a8a",
										"exec": [
											"// Генерирует случайное имя и сохраняет в переменную name",
											"const name = pm.collectionVariables.replaceIn(\"{{$randomFirstName}}\");",
											"// Выводит имя в консоль",
											"console.log(name);",
											"// Сохраняет имя в Collection переменную \"name\"",
											"pm.collectionVariables.set(\"name\", name);",
											"",
											"const fullname = pm.collectionVariables.replaceIn(\"{{$randomFullName}}\");",
											"console.log(\"fullname: \" + fullname);",
											"pm.collectionVariables.set(\"fullname\", fullname);",
											"",
											"console.log(\"Request level pre-request\")"
										],
										"type": "text/javascript",
										"packages": {},
										"requests": {}
									}
								},
								{
									"listen": "test",
									"script": {
										"id": "cb583889-564f-4c9d-9a54-d40e76ceb9ff",
										"exec": [
											"console.log(\"Request level post-response\")",
											"",
											"pm.test(\"access-control-allow-methods header check\", function () {",
											"    var header = pm.response.headers.get(\"access-control-allow-methods\");",
											"    pm.expect(header).to.eql(\"GET, POST, DELETE, PUT\");",
											"});",
											"",
											"pm.test(\"access-control-allow-origin header check\", function () {",
											"    var header = pm.response.headers.get(\"access-control-allow-origin\");",
											"    pm.expect(header).to.eql(\"*\");",
											"});",
											"",
											"pm.test(\"ID is correct\", function () {",
											"    var jsonData = pm.response.json().id;",
											"    pm.expect(jsonData).to.eql(Number (pm.environment.get(\"pet_id\")));",
											"});",
											"",
											"pm.test(\"CategoryName is correct\", function () {",
											"    var jsonData = pm.response.json().category;",
											"    pm.expect(jsonData.name).to.eql(pm.collectionVariables.get(\"name\"));",
											"});",
											"",
											"pm.test(\"Name is correct\", function () {",
											"    var jsonData = pm.response.json().name;",
											"    pm.expect(jsonData).to.eql(pm.collectionVariables.get(\"fullname\"));",
											"});",
											"pm.test(\"Status is available\", function () {",
											"    var jsonData = pm.response.json().status;",
											"    pm.expect(jsonData).to.eql(\"available\");",
											"});",
											"",
											"const getPetById = {",
											"    url: pm.globals.get(\"base_url\") + '/pet/' + pm.environment.get(\"pet_id\"),",
											"    method: 'GET',",
											"};",
											"pm.sendRequest(getPetById, function(error, response) {",
											"    pm.test(\"Pet is created and available\", function() {",
											"        var jsonData = response.json().id; ",
											"pm.expect(jsonData).to.eql(Number (pm.environment.get(\"pet_id\")));",
											"    });",
											"",
											"});"
										],
										"type": "text/javascript",
										"packages": {},
										"requests": {}
									}
								}
							],
