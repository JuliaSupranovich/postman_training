				{
					"name": "GET /pet/findByStatus",
					"item": [
						{
							"name": "Get pet by status",
							"event": [
								{
									"listen": "prerequest",
									"script": {
										"id": "2af6d42d-2295-4b0f-85af-daf585a6540a",
										"exec": [
											"const postPetRequest = {",
											"url: pm.globals.get(\"base_url\") + \"/pet\",",
											"method: 'POST', header: {",
											"'Content-Type':'application/json',",
											"},",
											"body: JSON.stringify({",
											"        \"id\": 12345,",
											"        \"category\": {",
											"            \"id\": 0,",
											"            \"name\": \"Dog\"",
											"        },",
											"        \"name\": \"TestPet\",",
											"        \"photoUrls\": [",
											"            \"string\"",
											"        ],",
											"        \"tags\": [",
											"            {",
											"                \"id\": 0,",
											"                \"name\": \"string\"",
											"            }",
											"        ],",
											"        \"status\": \"canceled\"",
											"    })",
											"};",
											"pm.sendRequest(postPetRequest, function(error, response) {",
											"    console.log(response.json());",
											"});"
										],
										"type": "text/javascript",
										"packages": {},
										"requests": {}
									}
								},
								{
									"listen": "test",
									"script": {
										"id": "eb72b764-ba71-495b-a202-65da3c30512b",
										"exec": [
											"pm.test(\"All pets have correct status\", function () {",
											"    var pets = pm.response.json();",
											"var allCorrectStatus = pets.every(pet => pet.status === pm.collectionVariables.get(\"pet_status\"));",
											"pm.expect(allCorrectStatus).to.be.true;",
											"});",
											"",
											"pm.test(\"Pets list is not null\", function () {",
											"       var jsonData = pm.response.json()",
											"pm.expect(jsonData).to.not.be.null",
											"});",
											"",
											"pm.test(\"Pets list is not empty\", function () {",
											"    var jsonData = pm.response.json();",
											"pm.expect(jsonData).to.have.length.above(0)",
											"});",
											"",
											"const getPetById = {",
											"    url: pm.globals.get(\"base_url\") + '/pet/findByStatus?status=canceled',",
											"    method: 'GET',",
											"};",
											"pm.sendRequest(getPetById, function(error, response) {",
											"    pm.test(\"Uniq status check\", function() {",
											"        var jsonData = response.json();",
											"        var myPet = jsonData.find(pet => pet.id === 12345);",
											"pm.expect(myPet.status).to.eql(\"canceled\");",
											"    });",
											"",
											"});",
											"//fork1"
										],
										"type": "text/javascript",
										"packages": {},
										"requests": {}
									}
								}
